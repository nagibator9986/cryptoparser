CRYPTO_MONITOR_ENV=production
CRYPTO_MONITOR_DB_PATH=/data/crypto_monitor.sqlite3
CRYPTO_MONITOR_SOURCES_FILE=/app/config/sources.example.yml
CRYPTO_MONITOR_SKILLS_ROOT=/app/crypto-monitor-skills

GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-2.5-flash

TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token

# Optional: CLI-only fallback delivery target. Group mode is configured in Telegram.
# TELEGRAM_CHAT_ID=

# Optional email delivery for CLI digest --email.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true

# Railway injects PORT automatically. Keep 8080 for local Docker runs.
PORT=8080

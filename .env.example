# Google AI Studio / Gemini API
GEMINI_API_KEY=put-your-key-here
GEMINI_MODEL=gemini-2.5-flash

# Runtime
CRYPTO_MONITOR_ENV=local
CRYPTO_MONITOR_DB_PATH=./data/crypto_monitor.sqlite3
CRYPTO_MONITOR_SKILLS_ROOT=./crypto-monitor-skills
CRYPTO_MONITOR_SOURCES_FILE=./config/sources.example.yml

# Delivery, optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

TELEGRAM_BOT_TOKEN=
# Optional for CLI digest --telegram. The command bot can register group chats itself.
TELEGRAM_CHAT_ID=
